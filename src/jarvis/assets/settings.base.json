{
  "$comment": "Jarvis OS baseline Claude Code settings, injected into every managed project. Project-specific needs belong in the catalog's settings_overrides, not here and not in the project.",
  "env": {
    "JARVIS_MANAGED": "1"
  },
  "permissions": {
    "allow": ["Bash(jarvis *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "$comment": "Mirrors Claude Code's own memory files into the OS knowledge base.",
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "__JARVIS_HOOK_CMD__", "timeout": 30 }
        ]
      }
    ]
  }
}
